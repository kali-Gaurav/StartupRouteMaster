# Gemini API Keys (backup method - rotating keys for rate limit handling)
# ============================================================================
# Individual API keys for load balancing and failover
# Store actual keys in .env file (which is in .gitignore)

GEMINI_API_KEY1=your_api_key_1_here
GEMINI_API_KEY2=your_api_key_2_here
GEMINI_API_KEY3=your_api_key_3_here
GEMINI_API_KEY4=your_api_key_4_here
GEMINI_API_KEY5=your_api_key_5_here

# Optional: Primary API key (used if multiple keys not available)
GEMINI_API_KEY=your_primary_api_key_here

# Optional: Gemini model configuration
GEMINI_MODEL=gemini-pro-vision
GEMINI_TIMEOUT=30

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/routemaster_db

# ============================================================================
# Proxy Configuration (Optional)
# ============================================================================
# Comma-separated list of proxy URLs
PROXIES=http://proxy1.com:8080,http://proxy2.com:8080
PROXY_TIMEOUT=5
PROXY_FAIL_THRESHOLD=0.5

# ============================================================================
# RMA (RouteMaster Agent) Configuration
# ============================================================================
RMA_PROXY_CHECK_INTERVAL=300
RMA_PROXY_CHECK_TIMEOUT=5
RMA_PROXY_FAIL_THRESHOLD=0.5

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/routemaster.log

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_DISHA_VERIFICATION=true
ENABLE_RELIABILITY_SCHEDULER=true
ENABLE_PROXY_MONITORING=true

# Environment
ENVIRONMENT=development

# RapidAPI configuration for live IRCTC lookups (use your own key)
# DO NOT commit real secrets; keep them in .env only.
RAPIDAPI_KEY=

# Live API and RapidAPI endpoints (production values only) – no mocks.
# Leave booking/seat/fare URLs blank until booking integration begins.
RAPIDAPI_HOST=irctc1.p.rapidapi.com
LIVE_STATUS_BASE_URL=https://rappid.in/apis/train.php
ENABLE_LIVE_STATUS=true
ENABLE_SEAT_VERIFICATION=true
ENABLE_FARE_VERIFICATION=true
VERIFICATION_CACHE_TTL=180
