{
  "$schema": "https://railway.app/npm/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "startCommand": "cd backend && uvicorn app:app --host 0.0.0.0 --port $PORT --proxy-headers",
    "restartPolicyType": "ON_FAILURE",
    "rootDirectory": "backend"
  }
}
