      "targets": [
        {
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT id, user_id, status, location, description, created_at, updated_at FROM sos_alerts WHERE status = 'active' ORDER BY created_at DESC LIMIT 200",
          "datasource": "${PostgresDS}"
        }
      ],
      "title": "Active SOS Alerts (table)",
      "type": "table"
    },
    {
      "datasource": "${PostgresDS}",
      "fieldConfig": {"defaults": {},"overrides": []},
      "gridPos": {"h": 4,"w": 6,"x": 0,"y": 6},
      "id": 4,
      "options": {},
      "targets": [
        {
          "datasource": "${PostgresDS}",
          "format": "time_series",
          "refId": "A",
          "rawSql": "SELECT $__timeGroup(created_at,'1m') AS time, count(*) AS value FROM sos_alerts WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1"
        }
      ],
      "title": "SOS Alerts over time",
      "type": "timeseries"
    },
    {
      "datasource": "${PostgresDS}",
      "fieldConfig": {"defaults": {},"overrides": []},
      "gridPos": {"h": 4,"w": 6,"x": 6,"y": 6},
      "id": 6,
      "options": {"reduceOptions": {"calcs": ["last"],"fields": "","values": false}},
      "targets": [
        {
          "datasource": "${PostgresDS}",
          "format": "time_series",
          "refId": "A",
          "rawSql": "SELECT $__timeGroup(created_at,'1m') AS time, sum(CASE WHEN status='active' THEN 1 ELSE 0 END) AS value FROM sos_alerts WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1"
        }
      ],
      "title": "Active alerts (count)",
      "type": "stat",
      "alert": {
        "name": "Active SOS alerts > 0",
        "severity": "critical",
        "frequency": "10s",
        "for": "30s",
        "conditions": [
          {
            "type": "query",
            "query": {"params": ["A"]},
            "reducer": {"type": "last", "params": []},
            "evaluator": {"type": "gt", "params": [0]},
            "operator": {"type": "and"}
          }
        ],
        "noDataState": "ok",
        "executionErrorState": "alerting",
        "notifications": []
      }
    },
