SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
DATABASE_URL=postgresql://user:password@localhost:5432/routemaster

RAZORPAY_KEY_ID=your_razorpay_key_id
