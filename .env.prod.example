# Production Environment Variables
# Copy this to .env.prod and fill in actual values before deployment
# Usage: docker-compose --env-file .env.prod up -d

# ============================================================================
# INFRASTRUCTURE
# ============================================================================

# Environment mode
ENVIRONMENT=production
LOG_LEVEL=INFO

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Primary PostgreSQL (used by most services)
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/postgres

# RouteMaster-specific PostgreSQL
ROUTEMASTER_DB_URL=postgresql://postgres:CHANGE_ME@routemaster_db:5432/routemaster

# RouteMaster ML Database
ROUTEMASTER_ML_DB_URL=postgresql://routemaster:CHANGE_ME@routemaster_ml_db:5432/routemaster_ml

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# ============================================================================
# JWT & SECURITY
# ============================================================================

# JWT Secret Key (use: openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# JWT Token Expiration (in hours)
JWT_EXPIRATION_HOURS=24

# JWT Refresh Token Expiration (in days)
JWT_REFRESH_EXPIRATION_DAYS=30

# ============================================================================
# PAYMENT PROCESSING
# ============================================================================

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_live_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
# RevenueCat removed; no server API key needed

# Stripe (https://dashboard.stripe.com) - Optional
STRIPE_PUBLIC_KEY=pk_live_CHANGE_ME
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ============================================================================
# NOTIFICATION SERVICES
# ============================================================================

# Twilio (SMS notifications)
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email notifications)
# Get from: https://sendgrid.com/dynamic_mail_settings/sender_authentication
SENDGRID_API_KEY=SG.CHANGE_ME

# Email from address
FROM_EMAIL=noreply@routemaster.com
FROM_NAME=RouteMaster

# ============================================================================
# AI/CHATBOT
# ============================================================================

# OpenRouter (for LLM-powered chat)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-CHANGE_ME

# Alternative: OpenAI
# OPENAI_API_KEY=sk-CHANGE_ME

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend API URL (what the browser uses to call backend)
FRONTEND_API_URL=https://api.routemaster.com
# Or for same-origin setup:
# FRONTEND_API_URL=/api

# Frontend App Base URL (for redirects, links)
FRONTEND_BASE_URL=https://routemaster.com

# Frontend Telegram Bot ID
TELEGRAM_BOT_ID=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij

# ============================================================================
# API GATEWAY CONFIGURATION
# ============================================================================

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://routemaster.com,https://www.routemaster.com,https://app.routemaster.com

# Backend Service URLs (internal Docker network)
SCRAPER_URL=http://scraper:8001
ROUTE_URL=http://route_service:8002
RL_URL=http://rl_service:8003
USER_URL=http://user_service:8004
PAYMENT_URL=http://payment_service:8005
NOTIFICATION_URL=http://notification_service:8006

# ============================================================================
# OBSERVABILITY & MONITORING
# ============================================================================

# Grafana Admin Password
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password

# Sentry Error Tracking
SENTRY_DSN=https://key@sentry.io/project

# ============================================================================
# EXTERNAL SERVICES (3rd party APIs)
# ============================================================================

# Train Data Source (IRCTC, if available)
IRCTC_API_URL=https://api.irctc.example.com
IRCTC_API_KEY=e0adaea886msh3fb9b9456cad9ccp17a317jsna7fe7b2fe0b6
LIVE_STATUS_BASE_URL=https://rappid.in/apis/train.php
ENABLE_LIVE_STATUS=true
ENABLE_SEAT_VERIFICATION=true
ENABLE_FARE_VERIFICATION=true
VERIFICATION_CACHE_TTL=180
RAPIDAPI_KEY=CHANGE_ME
RAPIDAPI_HOST=irctc1.p.rapidapi.com

# Google Cloud (for geolocation, distance matrix)
GOOGLE_MAPS_API_KEY=CHANGE_ME

# Firebase (for push notifications, optional)
FIREBASE_PROJECT_ID=CHANGE_ME
FIREBASE_PRIVATE_KEY_ID=CHANGE_ME
FIREBASE_PRIVATE_KEY=CHANGE_ME
FIREBASE_CLIENT_EMAIL=CHANGE_ME@firebase.iam.gserviceaccount.com

# AWS (S3 for file storage, optional)
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=routemaster-prod
AWS_REGION=ap-south-1

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Max concurrent connections
MAX_CONNECTIONS=1000

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Cache TTL (seconds)
CACHE_TTL=3600

# Database connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=1800

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=10000

# ============================================================================
# BACKUP & RECOVERY
# ============================================================================

# Backup frequency (cron format: 0 2 * * * = 2 AM daily)
BACKUP_SCHEDULE=0 2 * * *

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features
FEATURE_CHATBOT_ENABLED=true
FEATURE_SOS_ENABLED=true
FEATURE_REAL_TIME_TRACKING_ENABLED=true
FEATURE_PAYMENT_ENABLED=true
FEATURE_REFERRAL_ENABLED=false

# ============================================================================
# NOTES
# ============================================================================

# 1. SECURITY:
#    - Change all CHANGE_ME values before deploying
#    - Use strong, random values for JWT_SECRET_KEY and DB passwords
#    - Never commit actual .env.prod to git
#    - Rotate secrets regularly
#
# 2. CERTIFICATES:
#    Place SSL certificates in:
#    - ./monitoring/nginx/ssl/cert.pem
#    - ./monitoring/nginx/ssl/key.pem
#    Or use Let's Encrypt (certbot)
#
# 3. BACKUPS:
#    Configure automated backups:
#    - Docker volumes to cloud storage (S3)
#    - PostgreSQL to S3 via pg_dump
#    - Redis snapshots
#
# 4. MONITORING:
#    - Prometheus scrapes /metrics at :8000
#    - Grafana at :3000 (update password!)
#    - Set up alerts for critical metrics
#
# 5. LOGGING:
#    - Loki aggregates logs from all containers
#    - View in Grafana Explore → Loki
#    - Configure log retention per container
#
# 6. TESTING:
#    Before going live:
#    - Load test with k6 or Locust
#    - Chaos test: kill containers, verify recovery
#    - Test payment flow with test credentials
#    - Verify email/SMS notifications work
