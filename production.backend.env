# --- PLATFORM: RAILWAY BACKEND API ---
# Copy everything below and paste into Railway -> Variables -> Bulk Import

ENVIRONMENT=production
PYTHONPATH=.

# DB & CACHE
DATABASE_URL=PASTE_YOUR_RAILWAY_POSTGRES_URL_HERE
REDIS_URL=PASTE_YOUR_UPSTASH_REDIS_URL_HERE

# SUPABASE AUTH
SUPABASE_URL=PASTE_YOUR_SUPABASE_URL_HERE
SUPABASE_SERVICE_KEY=PASTE_YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# SECURITY & CORS
JWT_SECRET_KEY=PASTE_A_LONG_RANDOM_STRING_HERE
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# EXTERNAL API (IRCTC Sync)
RAPIDAPI_KEY=PASTE_YOUR_RAPID_API_KEY_HERE
RAPIDAPI_HOST=irctc1.p.rapidapi.com
